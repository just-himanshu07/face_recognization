# Backend Configuration
# Environment variables for the FastAPI backend

# Port to run the server on (default: 8000)
PORT=8000

# Database URL (default: SQLite at ./attendance.db)
# Uncomment and modify for other databases
# DATABASE_URL=sqlite:///./attendance.db

# CORS settings - for production, specify your frontend URL
# Leave as "*" for development (allow all origins)
# For production: CORS_ORIGINS=https://your-frontend.netlify.app
CORS_ORIGINS=*

